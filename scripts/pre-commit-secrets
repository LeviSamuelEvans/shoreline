#!/usr/bin/env sh
set -eu

failed=0

staged_files() {
	git diff --cached --name-only --diff-filter=ACMR
}

check_filename() {
	path=$1
	name=$(basename "$path")

	case "$name" in
	.env|.env.*|secrets.json|credentials.json|*.pem|*.key|*.p12|*.pfx)
		echo "blocked secret-like file: $path" >&2
		failed=1
		;;
	esac
}

check_contents() {
	path=$1

	numstat=$(git diff --cached --numstat -- "$path")
	case "$numstat" in
	-*)
		return 0
		;;
	esac

	git show ":$path" 2>/dev/null | awk -v path="$path" '
		/-----BEGIN [A-Z ]*PRIVATE KEY-----/ {
			printf "%s:%d: private key material\n", path, NR > "/dev/stderr"
			found = 1
		}
		/(client_secret|access_token|refresh_token|api[_-]?key|authorization)[[:space:]]*[:=][[:space:]]*["'\''][^"'\'']{12,}["'\'']/ {
			if ($0 !~ /["'\'']\.\.\.["'\'']/ && $0 !~ /["'\'']example["'\'']/) {
				printf "%s:%d: possible secret assignment\n", path, NR > "/dev/stderr"
				found = 1
			}
		}
		/(Bearer|OAuth)[[:space:]]+[A-Za-z0-9._~+\/=-]{20,}/ {
			printf "%s:%d: possible bearer token\n", path, NR > "/dev/stderr"
			found = 1
		}
		END {
			if (found) {
				exit 1
			}
		}
	' || failed=1
}

for path in $(staged_files); do
	check_filename "$path"
	check_contents "$path"
done

if [ "$failed" -ne 0 ]; then
	echo "pre-commit secret scan failed; remove the secret or unstage the file" >&2
	exit 1
fi
